# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT=30

# OpenAI Assistants API (опционально, для подключения базы знаний)
# Если указан OPENAI_ASSISTANT_ID, будет использоваться Assistants API вместо Chat Completions
# OPENAI_ASSISTANT_ID=asst_xxxxxxxxxxxxx
# VECTOR_STORE_ID=vs_xxxxxxxxxxxxx

# System Prompt
# Используется только если НЕ указан OPENAI_ASSISTANT_ID
SYSTEM_PROMPT=Ты — AI-ассистент сайта-портфолио Андрея, специалиста по автоматизации и AI. Твоя задача: помогать посетителям разобраться с услугами, кейсами и форматом работы. Отвечай на вопросы о том, как Андрей может помочь с автоматизацией поддержки, обработкой документов, AI-ассистентами и интеграциями. Если нужна персональная консультация или обсуждение конкретного проекта, направляй к контактам.

# Widget Configuration
WELCOME_MESSAGE=Привет! Я AI-ассистент этого сайта.\n\nПомогу разобраться с услугами, посмотреть подходящие кейсы или ответить на вопросы о том, как Андрей может помочь с автоматизацией.\n\nЧто вас интересует?
MANAGER_CONTACT=https://t.me/eth1r
