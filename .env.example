# Contact Form Configuration
# Настройка формы обратной связи

# Endpoint для отправки формы
# Если не указан, используется mailto fallback
# VITE_CONTACT_ENDPOINT=https://your-api.com/contact
# VITE_CONTACT_ENDPOINT=/api/contact

# HTTP метод для отправки
# VITE_CONTACT_METHOD=POST

# Примеры настройки:
# 1. Для использования mailto (по умолчанию):
#    Не указывайте VITE_CONTACT_ENDPOINT

# 2. Для отправки на свой API:
#    VITE_CONTACT_ENDPOINT=https://api.example.com/contact
#    VITE_CONTACT_METHOD=POST

# 3. Для отправки через webhook (например, n8n, Zapier):
#    VITE_CONTACT_ENDPOINT=https://hooks.zapier.com/hooks/catch/xxx/yyy
#    VITE_CONTACT_METHOD=POST

# 4. Для отправки через Telegram Bot:
#    VITE_CONTACT_ENDPOINT=https://api.telegram.org/botXXX:YYY/sendMessage
#    VITE_CONTACT_METHOD=POST

# AI Chat Widget Configuration
# Настройка AI-чат виджета

# URL для API чата (в продакшене проксируется через nginx)
# VITE_API_URL=/api

# Backend будет использовать переменные из backend/.env:
# - OPENAI_API_KEY
# - OPENAI_MODEL
# - SYSTEM_PROMPT
# - WELCOME_MESSAGE
# - MANAGER_CONTACT
